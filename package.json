{
    "name": "nmd-highlighter",
    "displayName": "Notes Markdown (NMD) Highlighter",
    "version": "0.1.0",
    "publisher": "jtpeller",
    "description": "Customizable semantic highlighting and gutter icons for Notes Markdown (.nmd) files",
    "author": {
        "name": "jtpeller"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "icon": "assets/images/icon.webp",
    "galleryBanner": {
        "color": "#0a0a0a",
        "theme": "dark"
    },
    "pricing": "Free",
    "repository": {
        "type": "git",
        "url": "https://github.com/jtpeller/nmd-highlighter.git"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:markdown"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "nmdHighlighter.insertTimestamp",
                "title": "Insert Current Timestamp",
                "category": "NMD Highlighter"
            },
            {
                "command": "nmdHighlighter.insertRightArrow",
                "title": "Insert LaTeX Right Arrow",
                "category": "NMD Highlighter"
            },
            {
                "command": "nmdHighlighter.insertDefinitionTemplate",
                "title": "Insert Definition Template",
                "category": "NMD Highlighter"
            },
            {
                "command": "nmdHighlighter.generateMonthlyTemplate",
                "title": "Generate Monthly Template",
                "category": "NMD Highlighter"
            },
            {
                "command": "nmdHighlighter.showIconGallery",
                "title": "Show Icon Gallery",
                "category": "NMD Highlighter"
            }
        ],
        "keybindings": [
            {
                "command": "nmdHighlighter.insertTimestamp",
                "key": "ctrl+shift+t",
                "mac": "cmd+shift+t",
                "when": "editorTextFocus && editorLangId == markdown"
            },
            {
                "command": "nmdHighlighter.insertRightArrow",
                "key": "ctrl+k `",
                "mac": "cmd+k `",
                "when": "editorTextFocus && editorLangId == markdown"
            },
            {
                "command": "nmdHighlighter.insertDefinitionTemplate",
                "key": "ctrl+k ctrl+d",
                "mac": "cmd+k cmd+d",
                "when": "editorTextFocus && editorLangId == markdown"
            }
        ],
        "markdown.markdownItPlugins": true,
        "markdown.previewStyles": [
            "./styles/nmd-styles.css"
        ],
        "languages": [
            {
                "id": "markdown",
                "extensions": [
                    ".nmd"
                ]
            }
        ],
        "configuration": {
            "title": "Notes Markdown (NMD) Highlighter",
            "properties": {
                "NMDHighlighter.definitionColor": {
                    "type": "string",
                    "format": "color-hex",
                    "default": "#009f9f",
                    "description": "The default color used for LaTeX template definitions."
                },
                "NMDHighlighter.enabled": {
                    "default": {
                        "issue": true,
                        "bug": true,
                        "task": true,
                        "fix": true,
                        "done": true,
                        "verified": true,
                        "notes": true
                    },
                    "markdownDescription": "%NMDHighlighter.enabled.description%",
                    "scope": "resource",
                    "type": "object",
                    "items": {
                        "type": "boolean"
                    }
                },
                "NMDHighlighter.keywords": {
                    "default": {
                        "issue": [
                            "ISSUE",
                            "CRITICAL"
                        ],
                        "bug": [
                            "BUG",
                            "FIXME"
                        ],
                        "task": [
                            "TASK",
                            "SUBTASK",
                            "TODO"
                        ],
                        "fix": [
                            "FIX"
                        ],
                        "done": [
                            "DONE"
                        ],
                        "verified": [
                            "VERIFIED"
                        ],
                        "notes": [
                            "NOTE",
                            "INFO",
                            "COMMENT",
                            "// "
                        ]
                    },
                    "additionalProperties": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "markdownDescription": "%NMDHighlighter.keywords.description%",
                    "scope": "resource",
                    "type": "object"
                },
                "NMDHighlighter.icons": {
                    "default": {
                        "issue": "exclaim",
                        "bug": "bug",
                        "task": "lightning",
                        "fix": "checkmark",
                        "done": "checkmark",
                        "verified": "star",
                        "notes": "pencil"
                    },
                    "additionalProperties": {
                        "type": "string",
                        "enum": [
                            "asterisk",
                            "bug",
                            "bug2",
                            "checkmark",
                            "down",
                            "exclaim",
                            "flag",
                            "git",
                            "info",
                            "key",
                            "left",
                            "lightning",
                            "pause",
                            "pencil",
                            "person",
                            "plane",
                            "play",
                            "reset",
                            "right",
                            "star",
                            "stop",
                            "unlock",
                            "up",
                            "warning"
                        ],
                        "enumItemLabels": [
                            "Asterisk",
                            "Bug",
                            "Bug (Alt)",
                            "Checkmark",
                            "Down Arrow",
                            "Exclamation Point",
                            "Flag",
                            "Git Branch",
                            "Info",
                            "Key",
                            "Left Arrow",
                            "Lightning Bolt",
                            "Pause",
                            "Pencil",
                            "Person",
                            "Plane",
                            "Play",
                            "Reset",
                            "Right Arrow",
                            "Star",
                            "Stop",
                            "Unlock",
                            "Up Arrow",
                            "Warning"
                        ],
                        "markdownEnumDescriptions": [
                            "![asterisk](assets/icons/asterisk.svg) A simple multi-pointed asterisk or star symbol.",
                            "![bug](assets/icons/bug.svg) A beetle-like bug icon, ideal for marking software defects.",
                            "![bug2](assets/icons/bug2.svg) An alternate bug icon variant.",
                            "![checkmark](assets/icons/checkmark.svg) A checkmark icon for verified or completed items.",
                            "![down](assets/icons/down.svg) A standard downward-pointing arrow.",
                            "![exclaim](assets/icons/exclaim.svg) A circular icon containing an exclamation point for issues or warnings.",
                            "![flag](assets/icons/flag.svg) A triangular flag icon for marking milestones or points of interest.",
                            "![git](assets/icons/git.svg) A branch symbol for Git or version control related notes.",
                            "![info](assets/icons/info.svg) A circular info icon for helpful annotations.",
                            "![key](assets/icons/key.svg) A key icon for passwords, secrets, or access-related notes.",
                            "![left](assets/icons/left.svg) A left-pointing arrow icon.",
                            "![lightning](assets/icons/lightning.svg) A lightning bolt icon for high-priority or urgent tasks.",
                            "![pause](assets/icons/pause.svg) A standard vertical-bar pause symbol.",
                            "![pencil](assets/icons/pencil.svg) A pencil icon representing a draft, edit, or general note.",
                            "![person](assets/icons/person.svg) A person silhouette icon for assignments or user-specific notes.",
                            "![plane](assets/icons/plane.svg) A plane icon for travel, shipping, or deployment notes.",
                            "![play](assets/icons/play.svg) A triangle play button symbol for starting processes.",
                            "![reset](assets/icons/reset.svg) A circular arrow icon for resets, refreshes, or repeating tasks.",
                            "![right](assets/icons/right.svg) A right-pointing arrow icon.",
                            "![star](assets/icons/star.svg) A 5-pointed star icon for favorites, highlights, or achievements.",
                            "![stop](assets/icons/stop.svg) A standard square stop symbol.",
                            "![unlock](assets/icons/unlock.svg) An open padlock icon representing security or access status.",
                            "![up](assets/icons/up.svg) An upward-pointing arrow.",
                            "![warning](assets/icons/warning.svg) A warning triangle for critical alerts, hazards, or attention."
                        ]
                    },
                    "markdownDescription": "%NMDHighlighter.icons.description%",
                    "scope": "resource",
                    "type": "object"
                },
                "NMDHighlighter.fgColors": {
                    "default": {
                        "issue": "#FF5252",
                        "bug": "#FF6900",
                        "task": "#FFB300",
                        "fix": "#448AFF",
                        "done": "#4CAF50",
                        "verified": "#FFFFFF",
                        "notes": "#fc79b2"
                    },
                    "additionalProperties": {
                        "type": "string",
                        "format": "color-hex",
                        "default": "#FFFFFF"
                    },
                    "markdownDescription": "%NMDHighlighter.fgColors.description%",
                    "scope": "resource",
                    "type": "object"
                },
                "NMDHighlighter.bgColors": {
                    "default": {
                        "issue": "#00000000",
                        "bug": "#00000000",
                        "task": "#00000000",
                        "fix": "#00000000",
                        "done": "#00000000",
                        "verified": "#137216",
                        "notes": "#00000000"
                    },
                    "additionalProperties": {
                        "type": "string",
                        "format": "color-hex",
                        "default": "#00000000"
                    },
                    "markdownDescription": "%NMDHighlighter.bgColors.description%",
                    "scope": "resource",
                    "type": "object"
                }
            }
        }
    },
    "scripts": {
        "compile": "npm run check-types && node esbuild.js",
        "check-types": "tsc --noEmit",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "vscode:prepublish": "npm run package",
        "package": "npm run check-types && node esbuild.js --production"
    },
    "devDependencies": {
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^16.18.126",
        "@types/vscode": "^1.80.0",
        "esbuild": "^0.27.4",
        "ts-node": "^10.9.2",
        "typescript": "^5.x"
    }
}
